# Build / export artifacts — regenerated by `godot --export` (see docs/iOS_BUILD.md)
build/

# Safety net: never commit large export outputs even if exported outside build/
*.pck
*.xcframework/

# Godot editor cache & reimported binaries
.godot/

# macOS
.DS_Store

# Local scratch / transient overrides
/tmp/
override.cfg
/archive/

# Grove art import-skip toggle: a LOCAL build-speed switch, not source.
# `make run_base` creates it (placeholder boots without importing grove art);
# `make run_grove` removes it (grove art imports + loads). Either way: never committed.
games/grove/assets/.gdignore

# raw LLM image drops (process via slice_grid + make icon/decor; not committed)
assets/llm/
