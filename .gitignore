# Build / export artifacts — regenerated by `godot --export` (see docs/iOS_BUILD.md)
build/
!build/
build/*
!build/ios/
build/ios/*
!build/ios/ci_scripts/
!build/ios/ci_scripts/ci_post_clone.sh

# Safety net: never commit large export outputs even if exported outside build/
*.pck
*.xcframework/

# iOS Apple-services plugin (Game Center + StoreKit) — large prebuilt binaries,
# fetched per-checkout by `make ios-plugins` (tools/install_ios_plugins.sh).
# Regenerable like the baked caches, so the whole dir is ignored; the script is
# the source of truth (pinned release).
/addons/

# Godot editor cache & reimported binaries (the bare form also ignores a
# worktree `.godot` symlink, which `.godot/` would not match)
.godot/
.godot

# macOS
.DS_Store

# Python bytecode cache (tools/)
__pycache__/
*.pyc

# Local scratch / transient overrides
/tmp/
override.cfg
/archive/

# Grove art import-skip toggle: a LOCAL build-speed switch, not source.
# `make run_base` creates it (placeholder boots without importing grove art);
# `make run_grove` removes it (grove art imports + loads). Either way: never committed.
games/grove/assets/.gdignore

# raw LLM image drops (process via slice_grid + make icon/decor; not committed)
games/placeholder/assets/llm/

# Brainstorm visual companion scratch
.superpowers/

# Local feature worktrees
.worktrees/
