; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tidy Up"
config/description="Cozy merge-and-tidy: combine clutter, clear the room, relax."
run/main_scene="res://engine/scenes/Boot.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.png"
boot_splash/bg_color=Color(0.956, 0.933, 0.874, 1)
boot_splash/image="res://games/grove/assets/ui/boot/logo_tidyup.png"
boot_splash/fullsize=false

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=2
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
